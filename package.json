{
  "name": "changelog-render-action",
  "version": "1.0.0",
  "description": "GitHub Action that renders insights.v1.json into formatted changelog markdown",
  "main": "dist/index.js",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --outfile=dist/index.js --sourcemap",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint src tests --ext .ts",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build"
  },
  "keywords": [
    "github-action",
    "changelog",
    "markdown",
    "release-notes"
  ],
  "author": "marco-jardim",
  "license": "GPL-3.0",
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/github": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.2",
    "esbuild": "^0.27.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
