{
  "name": "changelog-render-action",
  "version": "1.0.0",
  "description": "GitHub Action that renders insights.v1.json into formatted changelog markdown",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && ncc build dist/index.js -o dist --minify --no-cache",
    "build:tsc": "tsc",
    "build:bundle": "ncc build src/index.ts -o dist --minify --no-cache",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src tests --ext .ts",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build:bundle"
  },
  "keywords": [
    "github-action",
    "changelog",
    "markdown",
    "release-notes"
  ],
  "author": "marco-jardim",
  "license": "GPL-3.0",
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "@vercel/ncc": "^0.38.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4",
    "typescript": "^5.4.5"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "collectCoverageFrom": [
      "src/**/*.ts"
    ],
    "coverageReporters": [
      "text",
      "lcov"
    ]
  }
}
